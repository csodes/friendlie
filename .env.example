# ---------------------------------------------------------------------------
# Friendlie environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase
# project dashboard (Project Settings → API).
# ---------------------------------------------------------------------------

# Public Supabase URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key. Safe to expose to the browser — Row Level Security protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER ONLY. Never expose to the browser.
# Used for moderation/admin tasks that must bypass RLS. Optional for the MVP.
SUPABASE_SERVICE_ROLE_KEY=

# The canonical site URL, used for auth email redirect links.
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
